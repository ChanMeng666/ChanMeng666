{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ChanMeng666/ChanMeng666/schema/profile.schema.json",
  "title": "ChanMeng666 Profile Data Schema",
  "description": "Extended JSON Resume v1.0.0 schema with meta.x_brand namespace and structured narrative blocks for projects and work. Validates data/profile.yaml.",
  "type": "object",
  "additionalProperties": true,
  "required": ["basics", "meta"],
  "properties": {
    "basics": {
      "type": "object",
      "required": ["name", "label", "email", "url", "summary"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "alternateName": { "type": "string" },
        "label": { "type": "string" },
        "image": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "url": { "type": "string", "format": "uri" },
        "summary": { "type": "string", "minLength": 10 },
        "location": {
          "type": "object",
          "properties": {
            "address": { "type": "string" },
            "postalCode": { "type": "string" },
            "city": { "type": "string" },
            "countryCode": { "type": "string" },
            "region": { "type": "string" },
            "timezone": { "type": "string", "description": "IANA timezone identifier (e.g. 'Pacific/Auckland'). Used by JSON-LD ProfilePage and human-readable footer." }
          }
        },
        "profiles": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["network", "url"],
            "properties": {
              "network": { "type": "string" },
              "username": { "type": "string" },
              "label": { "type": "string" },
              "url": { "type": "string", "format": "uri" }
            }
          }
        },
        "taglines": {
          "type": "object",
          "description": "Custom field: hero taglines surfaced on the README.",
          "properties": {
            "primary": { "type": "string" },
            "secondary": { "type": "string" }
          }
        }
      }
    },

    "work": {
      "type": "array",
      "items": { "$ref": "#/$defs/workEntry" }
    },

    "volunteer": {
      "type": "array",
      "items": { "$ref": "#/$defs/workEntry" }
    },

    "education": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["institution"],
        "properties": {
          "id": { "type": "string" },
          "institution": { "type": "string" },
          "url": { "type": "string", "format": "uri" },
          "area": { "type": "string" },
          "studyType": { "type": "string" },
          "startDate": { "$ref": "#/$defs/loosePartialDate" },
          "endDate": { "$ref": "#/$defs/loosePartialDate" },
          "score": { "type": "string" },
          "courses": { "type": "array", "items": { "type": "string" } },
          "image": { "type": "string" },
          "location": { "type": "string" },
          "highlights": { "type": "array", "items": { "type": "string" } },
          "credentialId":  { "type": "string", "description": "Issuer-side unique identifier for the academic credential (e.g. NZ Record of Achievement number)." },
          "credentialUrl": { "type": "string", "format": "uri", "description": "Public verification URL for the academic credential." },
          "tier": { "$ref": "#/$defs/tierEnum" },
          "recency": { "$ref": "#/$defs/recencyEnum" },
          "lastUpdated": { "$ref": "#/$defs/loosePartialDate" }
        }
      }
    },

    "awards": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title"],
        "properties": {
          "title": { "type": "string" },
          "date": { "$ref": "#/$defs/loosePartialDate" },
          "awarder": { "type": "string" },
          "summary": { "type": "string" },
          "url": { "type": "string", "format": "uri" },
          "tier": { "$ref": "#/$defs/tierEnum" },
          "recency": { "$ref": "#/$defs/recencyEnum" },
          "lastUpdated": { "$ref": "#/$defs/loosePartialDate" }
        }
      }
    },

    "certificates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "issuer"],
        "properties": {
          "name": { "type": "string" },
          "date": { "$ref": "#/$defs/loosePartialDate" },
          "issuer": { "type": "string" },
          "url": { "type": "string", "format": "uri" },
          "credentialId": { "type": "string" },
          "image": { "type": "string" },
          "category": {
            "type": "string",
            "description": "Display grouping: hackerrank | microsoft | other | etc."
          },
          "issuerLogo": { "type": "string" },
          "tier": { "$ref": "#/$defs/tierEnum" },
          "recency": { "$ref": "#/$defs/recencyEnum" },
          "lastUpdated": { "$ref": "#/$defs/loosePartialDate" }
        }
      }
    },

    "publications": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string" },
          "publisher": { "type": "string" },
          "releaseDate": { "$ref": "#/$defs/loosePartialDate" },
          "url": { "type": "string", "format": "uri" },
          "summary": { "type": "string" },
          "image": { "type": "string" },
          "tier": { "$ref": "#/$defs/tierEnum" },
          "recency": { "$ref": "#/$defs/recencyEnum" },
          "lastUpdated": { "$ref": "#/$defs/loosePartialDate" },
          "meta": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "x_brand": {
                "type": "object",
                "additionalProperties": true,
                "properties": {
                  "type": {
                    "type": "string",
                    "description": "article | podcast | podcastShow | podcastEpisode | newsletter | interview | press | blog",
                    "enum": ["article", "podcast", "podcastShow", "podcastEpisode", "newsletter", "interview", "press", "blog"]
                  }
                }
              }
            }
          }
        }
      }
    },

    "skills": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string" },
          "level": { "type": "string" },
          "keywords": { "type": "array", "items": { "type": "string" } },
          "expertise": {
            "type": "array",
            "description": "Structured per-tool expertise: when adopted, depth, framework variants, supporting notes. Drives the Skills section richer rendering + JSON-LD knowsAbout enrichment.",
            "items": {
              "type": "object",
              "required": ["tool"],
              "additionalProperties": false,
              "properties": {
                "tool":       { "type": "string", "description": "Canonical tool/lang name; should match an existing entry in keywords[]." },
                "since":      { "type": "string", "pattern": "^[0-9]{4}(-[0-9]{2})?$", "description": "Adoption year (YYYY or YYYY-MM)." },
                "depth":      { "type": "string", "enum": ["expert", "intermediate", "learning"], "description": "Self-rated proficiency. expert = production-shipped + can teach; intermediate = shipped but not deeply; learning = active onboarding." },
                "frameworks": { "type": "array", "items": { "type": "string" }, "description": "Specific framework variants / libraries / patterns within this tool." },
                "notes":      { "type": "string", "description": "Optional one-line context: which project proves this, what's distinctive." }
              }
            }
          }
        }
      }
    },

    "domains": {
      "type": "array",
      "description": "Domain expertise (industry / problem-area specialization) — distinct from technical skills. Drives JSON-LD knowsAbout enrichment with verticals (e.g. Maori cultural technology, women's health, education technology, minimalist UX) so LLMs surface Chan for domain-shaped queries beyond raw tech stack.",
      "items": {
        "type": "object",
        "required": ["name"],
        "additionalProperties": false,
        "properties": {
          "id":                 { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "name":               { "type": "string", "minLength": 1 },
          "since":              { "type": "string", "pattern": "^[0-9]{4}(-[0-9]{2})?$" },
          "summary":            { "type": "string", "description": "1-2 sentences explaining what this domain means in Chan's practice and why she's a credible voice in it." },
          "evidenceProjectIds": { "type": "array", "items": { "type": "string", "pattern": "^[a-z0-9-]+$" }, "description": "Project ids that prove this domain expertise." },
          "evidenceWorkIds":    { "type": "array", "items": { "type": "string", "pattern": "^[a-z0-9-]+$" }, "description": "Work entry ids that prove this domain expertise." },
          "tier":               { "$ref": "#/$defs/tierEnum" },
          "recency":            { "$ref": "#/$defs/recencyEnum" },
          "lastUpdated":        { "$ref": "#/$defs/loosePartialDate" }
        }
      }
    },

    "languages": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "language": { "type": "string" },
          "fluency": { "type": "string" }
        }
      }
    },

    "interests": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string" },
          "keywords": { "type": "array", "items": { "type": "string" } }
        }
      }
    },

    "references": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "reference"],
        "properties": {
          "name": { "type": "string" },
          "reference": { "type": "string" },
          "tier": { "$ref": "#/$defs/tierEnum" },
          "recency": { "$ref": "#/$defs/recencyEnum" },
          "lastUpdated": { "$ref": "#/$defs/loosePartialDate" },
          "meta": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "x_brand": {
                "type": "object",
                "additionalProperties": true,
                "properties": {
                  "image": { "type": "string" },
                  "relationship": { "type": "string" },
                  "linkedinUrl": { "type": "string", "format": "uri" },
                  "verified": { "type": "boolean" },
                  "featured": { "type": "boolean" }
                }
              }
            }
          }
        }
      }
    },

    "projects": {
      "type": "array",
      "items": { "$ref": "#/$defs/projectEntry" }
    },

    "collaborators": {
      "type": "array",
      "description": "Real-human collaborator index — the entity-graph source-of-truth for JSON-LD Person.knows[]. Distinct from references[] (which holds LinkedIn-testimonial-quote records); a collaborator may or may not have written a testimonial.",
      "items": { "$ref": "#/$defs/collaboratorEntry" }
    },

    "organizations": {
      "type": "array",
      "description": "Organization entity index — promotes the legacy meta.x_brand.organisations[] roster to a top-level structured record so JSON-LD can emit one Organization node per entity with sameAs / description / founded / hq fields. The display-band logic (displayTier/category/context/relatedWorkId etc.) is preserved under meta.x_brand to keep existing templates unchanged.",
      "items": { "$ref": "#/$defs/organizationEntry" }
    },

    "meta": {
      "type": "object",
      "required": ["canonical", "version"],
      "properties": {
        "canonical": { "type": "string", "format": "uri" },
        "version": { "type": "string" },
        "lastModified": { "type": "string" },
        "x_brand": { "$ref": "#/$defs/xBrandMeta" }
      }
    }
  },

  "$defs": {
    "loosePartialDate": {
      "description": "ISO date (YYYY-MM-DD), partial (YYYY-MM, YYYY), or null/empty for present.",
      "oneOf": [
        { "type": "string", "pattern": "^[0-9]{4}(-[0-9]{2}(-[0-9]{2})?)?$" },
        { "type": "string", "enum": ["", "present"] },
        { "type": "null" }
      ]
    },

    "tierEnum": {
      "type": "string",
      "enum": ["flagship", "primary", "secondary", "archive"],
      "description": "Importance tier for LLM consumers. flagship = core identity (3-5 per list); primary = recommended source material (5-15 per list); secondary = complete record, surface only on deep-dive; archive = historical completeness only, LLMs should skip by default."
    },

    "recencyEnum": {
      "type": "string",
      "enum": ["active", "recent", "historical", "deprecated"],
      "description": "Current relevance signal. active = ongoing right now; recent = finished within ~12 months and still representative; historical = finished long ago but still on the record; deprecated = sunset / not for outbound use."
    },

    "organizationEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "url", "type", "tier"],
      "description": "An organization Chan has worked with, partnered with, or integrated. Drives JSON-LD Organization nodes and the README 'Trusted by' band. Replaces the legacy meta.x_brand.organisations[] roster; the display-band fields (displayTier, category, context, relatedWorkId/VolunteerId/ProjectId) live under meta.x_brand for template-stability.",
      "properties": {
        "id":           { "type": "string", "pattern": "^[a-z0-9-]+$" },
        "name":         { "type": "string", "minLength": 1 },
        "aliases":      { "type": "array", "items": { "type": "string" } },
        "url":          { "type": "string", "format": "uri" },
        "logo":         { "type": ["string", "null"], "description": "Path under /public/. Legacy roster used 'logoLight' — preserved as alias on the build-time cache." },
        "logoDark":     { "type": ["string", "null"] },
        "type":         { "type": "string", "enum": ["startup", "nonprofit", "enterprise", "community", "agency", "university", "gov"] },
        "industry":     { "type": "string", "description": "Free-form one-line industry: 'AI media agency', 'FemTech nonprofit', 'Public university'." },
        "hq": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "city":        { "type": "string" },
            "region":      { "type": "string" },
            "countryCode": { "type": "string", "pattern": "^[A-Z]{2}$" }
          }
        },
        "founded":      { "$ref": "#/$defs/loosePartialDate" },
        "description":  { "type": "string", "description": "1-2 sentences. Renders into JSON-LD Organization.description." },
        "sameAs":       { "type": "array", "items": { "type": "string", "format": "uri" }, "description": "Public-web sameAs URLs — LinkedIn company page is the most important entry; Crunchbase / Wikipedia / X also welcome." },
        "tier":         { "$ref": "#/$defs/tierEnum" },
        "recency":      { "$ref": "#/$defs/recencyEnum" },
        "lastUpdated":  { "$ref": "#/$defs/loosePartialDate" },
        "meta": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "x_brand": {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "displayTier":         { "type": "string", "enum": ["primary", "secondary"] },
                "category":            { "type": "string", "enum": ["employer", "partner", "vendor"] },
                "context":             { "type": "string" },
                "relatedWorkId":       { "type": ["string", "null"] },
                "relatedVolunteerId":  { "type": ["string", "null"] },
                "relatedProjectId":    { "type": ["string", "null"] }
              }
            }
          }
        }
      }
    },

    "collaboratorEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "relationship", "tier"],
      "description": "A real human Chan has worked with. Surfaces as Schema.org Person nodes inside Person.knows[] in JSON-LD, anchoring Chan to known professional identities on the open entity graph. The optional meta.x_brand.privateContact block is stripped from every rendered output by the build pipeline.",
      "properties": {
        "id":            { "type": "string", "pattern": "^[a-z0-9-]+$" },
        "name":          { "type": "string", "minLength": 1 },
        "aliases":       { "type": "array", "items": { "type": "string" } },
        "pronouns":      { "type": "string" },
        "currentTitle":  { "type": "string" },
        "currentOrgId":  { "type": "string", "pattern": "^[a-z0-9-]+$", "description": "References meta.x_brand.organisations[].id (or future top-level organizations[].id). May be omitted when the collaborator's current employer is not in our org index." },
        "linkedin":      { "type": "string", "format": "uri", "description": "PUBLIC contact channel — rendered into JSON-LD Person.url and Person.sameAs[]." },
        "github":        { "type": "string", "format": "uri" },
        "website":       { "type": "string", "format": "uri" },
        "sameAs":        { "type": "array", "items": { "type": "string", "format": "uri" }, "description": "Additional public profile URLs for JSON-LD Person.sameAs[] beyond linkedin/github/website." },
        "relationship":  {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "enum": ["mentor", "mentee", "client", "cofounder", "sponsor", "panelist", "student", "advisor", "reference", "collaborator", "colleague"] }
        },
        "worksTogether": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["contextType", "contextId"],
            "additionalProperties": false,
            "properties": {
              "contextType": { "type": "string", "enum": ["project", "work", "volunteer", "talk", "event", "cohort"] },
              "contextId":   { "type": "string", "pattern": "^[a-z0-9-]+$" },
              "role":        { "type": "string", "description": "Their role in this specific context, not their global title." }
            }
          }
        },
        "note":          { "type": "string", "maxLength": 280, "description": "One-line context for renders / hover tooltip." },
        "tier":          { "$ref": "#/$defs/tierEnum" },
        "recency":       { "$ref": "#/$defs/recencyEnum" },
        "lastUpdated":   { "$ref": "#/$defs/loosePartialDate" },
        "publicListing": { "type": "boolean", "description": "Default true. When false, the collaborator is included in dist/profile.json + llms-full.txt only, not in the public README." },
        "meta": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "x_brand": {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "image": { "type": "string", "description": "Optional headshot path under /public/." },
                "privateContact": {
                  "type": "object",
                  "description": "NEVER rendered. Schema-allowed for personal recordkeeping only; stripped from every output (README, llms*, dist/profile.json) by the build.",
                  "additionalProperties": false,
                  "properties": {
                    "email": { "type": "string", "format": "email" },
                    "phone": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },

    "narrativeProject": {
      "type": "object",
      "additionalProperties": false,
      "description": "Structured narrative for a project. Business and product logic lead; tech depth supports.",
      "properties": {
        "problem": { "type": "string", "description": "User pain or market gap addressed." },
        "audience": { "type": "string", "description": "Who it serves — persona, segment, scale, geography." },
        "productLogic": { "type": "string", "description": "How the product works at a user level; engagement loop." },
        "businessLogic": { "type": "string", "description": "Revenue model or theory of change; why viable." },
        "technicalApproach": { "type": "string", "description": "Architecture and hard problems solved, framed around impact." },
        "outcomes": { "type": "string", "description": "Real-world impact with verifiable numbers and sources." },
        "myRole": { "type": "string", "description": "Specific scope and contribution, with evidence." }
      }
    },

    "narrativeWork": {
      "type": "object",
      "additionalProperties": false,
      "description": "Structured narrative for a work experience.",
      "properties": {
        "companyContext": { "type": "string" },
        "mission": { "type": "string" },
        "myMandate": { "type": "string" },
        "impactDelivered": { "type": "string" },
        "technicalHighlights": { "type": "string" }
      }
    },

    "metricsItem": {
      "type": "object",
      "required": ["label", "value"],
      "properties": {
        "label": { "type": "string" },
        "value": { "type": "string" },
        "source": { "type": "string", "format": "uri" }
      }
    },

    "workEntry": {
      "type": "object",
      "required": ["id", "name", "position"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
        "name": { "type": "string" },
        "position": { "type": "string" },
        "url": { "type": "string", "format": "uri" },
        "startDate": { "$ref": "#/$defs/loosePartialDate" },
        "endDate": { "$ref": "#/$defs/loosePartialDate" },
        "summary": { "type": "string" },
        "highlights": { "type": "array", "items": { "type": "string" } },
        "location": { "type": "string" },
        "logo": { "type": "string" },
        "keywords": { "type": "array", "items": { "type": "string" } },
        "narrative": { "$ref": "#/$defs/narrativeWork" },
        "publicSummary": { "type": "string" },
        "featured": { "type": "boolean", "description": "Show in compact README experience table." },
        "tier": { "$ref": "#/$defs/tierEnum" },
        "recency": { "$ref": "#/$defs/recencyEnum" },
        "lastUpdated": { "$ref": "#/$defs/loosePartialDate" }
      }
    },

    "projectEntry": {
      "type": "object",
      "required": ["id", "name"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
        "name": { "type": "string" },
        "priority": {
          "type": "integer",
          "minimum": 1,
          "description": "1-4 = flagship card; 5+ = open-source listing."
        },
        "category": {
          "type": "string",
          "description": "For open-source grouping: web-apps | ai-apps | creative | ml-research | branding | games | infra | etc."
        },
        "tagline": { "type": "string" },
        "description": { "type": "string", "description": "JSON Resume short description (optional; we prefer narrative.*)." },
        "url": { "type": "string", "format": "uri" },
        "repoUrl": { "type": "string", "format": "uri" },
        "demoUrl": { "type": "string", "format": "uri" },
        "logo": { "type": "string" },
        "image": { "type": "string", "description": "Optional screenshot or hero image for the project." },
        "techStack": { "type": "array", "items": { "type": "string" } },
        "metrics": {
          "type": "array",
          "items": { "$ref": "#/$defs/metricsItem" }
        },
        "status": {
          "type": "string",
          "enum": ["production", "live", "active", "maintained", "archived", "draft"]
        },
        "startDate": { "$ref": "#/$defs/loosePartialDate" },
        "endDate": { "$ref": "#/$defs/loosePartialDate" },
        "narrative": { "$ref": "#/$defs/narrativeProject" },
        "publicSummary": { "type": "string" },
        "keywords": { "type": "array", "items": { "type": "string" } },
        "roles": { "type": "array", "items": { "type": "string" } },
        "entity": { "type": "string" },
        "type": { "type": "string" },
        "highlights": { "type": "array", "items": { "type": "string" } },
        "extraLinks": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["label", "url"],
            "properties": {
              "label": { "type": "string" },
              "url": { "type": "string", "format": "uri" }
            }
          }
        },
        "tier": { "$ref": "#/$defs/tierEnum" },
        "recency": { "$ref": "#/$defs/recencyEnum" },
        "lastUpdated": { "$ref": "#/$defs/loosePartialDate" }
      }
    },

    "xBrandMeta": {
      "type": "object",
      "additionalProperties": true,
      "description": "GEO and brand-specific metadata. Stripped from dist/profile.json (canonical JSON Resume artifact).",
      "properties": {
        "flagshipProjectIds": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Ordered IDs of projects rendered as flagship cards."
        },
        "openSourceCategoryOrder": {
          "type": "array",
          "items": { "type": "string" }
        },
        "openSourcePrimaryIds": {
          "type": "array",
          "items": { "type": "string" },
          "description": "IDs of projects in the primary Open Source table (the visible-by-default ones)."
        },
        "statisticsClaims": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["claim"],
            "properties": {
              "claim": { "type": "string" },
              "source": { "type": "string", "format": "uri" },
              "verifiedAt": { "type": "string" }
            }
          }
        },
        "citationPreference": { "type": "string" },
        "primarySocialBadges": {
          "type": "array",
          "items": { "type": "string" }
        },
        "additionalSameAs": {
          "type": "array",
          "items": { "type": "string", "format": "uri" }
        },
        "llmsTxtFooter": { "type": "string" },
        "yamlComments": { "type": "string" },
        "minimalistArticles": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["title", "url"],
            "properties": {
              "title": { "type": "string" },
              "url": { "type": "string", "format": "uri" },
              "platform": { "type": "string" }
            }
          }
        },
        "mediaAppearances": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["title", "url"],
            "properties": {
              "title": { "type": "string" },
              "url": { "type": "string", "format": "uri" },
              "platform": { "type": "string" }
            }
          }
        },
        "podcastsHosted": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "url"],
            "properties": {
              "name": { "type": "string" },
              "url": { "type": "string", "format": "uri" },
              "language": { "type": "string" },
              "description": { "type": "string" }
            }
          }
        },
        "footerLinks": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["label", "url", "description"],
            "properties": {
              "label": { "type": "string" },
              "url": { "type": "string", "format": "uri" },
              "description": { "type": "string" }
            }
          }
        },
        "cli": {
          "type": "object",
          "properties": {
            "command": { "type": "string" },
            "description": { "type": "string" }
          }
        },
        "agentInteractionStatistic": {
          "type": "object",
          "properties": {
            "publicRepos": { "type": "integer" },
            "followers": { "type": "integer" },
            "verifiedAt": { "type": "string" }
          }
        },
        "identifier": {
          "type": "string",
          "description": "Stable cross-surface entity ID emitted into JSON-LD."
        },

        "valueProposition": {
          "type": "object",
          "description": "Brand positioning surfaced in hero, llms.txt header, and JSON-LD Person.description.",
          "required": ["identity", "tagline"],
          "properties": {
            "identity": { "type": "string", "description": "Three-pillar role badge, e.g. 'AI Agent Architect · Founding-engineer · AI Educator'." },
            "tagline": { "type": "string", "description": "One-sentence value proposition." },
            "proofLine": { "type": "string", "description": "Optional inline proof stats." }
          }
        },

        "engagementRoles": {
          "type": "array",
          "description": "Four role archetypes Chan takes on. Surfaced as the 2×2 'What I take on' panel + Service[] in JSON-LD + ## section in llms.txt.",
          "items": {
            "type": "object",
            "required": ["id", "title", "scope", "format", "proofProjectId", "proofProjectName"],
            "properties": {
              "id":               { "type": "string", "pattern": "^[a-z0-9-]+$" },
              "title":            { "type": "string" },
              "scope":            { "type": "string" },
              "format":           { "type": "string" },
              "proofProjectId":   { "type": "string", "description": "ID of the project that best demonstrates this role; used to deep-link from the panel into Featured Work when the project is flagship-tier." },
              "proofProjectName": { "type": "string", "description": "Display name shown in the proof link." },
              "proofUrl":         { "type": "string", "format": "uri", "description": "Optional external URL — wins over in-page anchor when set. Use for non-flagship proof projects whose anchor isn't on the page." },
              "proofWorkId":      { "type": ["string", "null"] }
            }
          }
        },

        "engagementAvailability": {
          "type": "object",
          "description": "Open-to-work signal + preferred engagement formats + CTA links.",
          "required": ["current", "cta"],
          "properties": {
            "current":   { "type": "string" },
            "preferred": { "type": "array", "items": { "type": "string" } },
            "timezone":  { "type": "string" },
            "cta": {
              "type": "object",
              "required": ["primary"],
              "properties": {
                "primary":   { "$ref": "#/$defs/ctaLink" },
                "secondary": { "$ref": "#/$defs/ctaLink" }
              }
            }
          }
        },

        "faq": {
          "type": "array",
          "description": "Employer-facing Q&A pairs. Emitted as schema.org FAQPage in JSON-LD + ## Frequently asked section in llms.txt / llms-full.txt.",
          "items": {
            "type": "object",
            "required": ["question", "answer"],
            "properties": {
              "question": { "type": "string" },
              "answer":   { "type": "string" }
            }
          }
        },

        "teachingCohorts": {
          "type": "array",
          "description": "Four AI-programming cohorts Chan has led since 2024. Surfaced as the AI Mentor 2×2 grid + ItemList<EducationalOccupationalProgram> in JSON-LD + ## section in llms.txt.",
          "items": {
            "type": "object",
            "required": ["id", "cohortLabel", "programName", "partnerOrg", "audience", "format", "dateRange", "keyOutcome", "curriculumUrl"],
            "properties": {
              "id":             { "type": "string", "pattern": "^[a-z0-9-]+$" },
              "cohortLabel":    { "type": "string", "description": "Short badge, e.g. 'Winter 2024'." },
              "programName":    { "type": "string" },
              "partnerOrg":     { "type": "string" },
              "partnerOrgIds":  { "type": "array", "items": { "type": "string" }, "description": "Optional org ids whose logos render inline on the cohort card." },
              "audience":       { "type": "string" },
              "format":         { "type": "string" },
              "dateRange":      { "type": "string" },
              "keyOutcome":     { "type": "string" },
              "curriculumUrl":  { "type": "string", "format": "uri" },
              "relatedWorkId":      { "type": ["string", "null"] },
              "relatedVolunteerId": { "type": ["string", "null"] },
              "relatedProjectId":   { "type": ["string", "null"] }
            }
          }
        },

        "teachingImpact": {
          "type": "object",
          "description": "Pre-aggregated teaching-reach stats surfaced under the AI Mentor section header.",
          "required": ["cohortCount"],
          "properties": {
            "cohortCount":         { "type": "integer", "minimum": 0 },
            "learnerReachClaim":   { "type": "string" },
            "menteeRefsClaim":     { "type": "string" },
            "flagshipAwardClaim":  { "type": "string" }
          }
        }
      }
    },

    "ctaLink": {
      "type": "object",
      "required": ["label", "url"],
      "properties": {
        "label": { "type": "string" },
        "url":   { "type": "string" }
      }
    }
  }
}
