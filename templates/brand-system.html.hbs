      <p class="lead">{{identity.tagline}}</p>
      <div class="cta-row">
        <a class="btn btn-primary" href="../dist/brand/DESIGN.md">Read the spec</a>
        <a class="btn btn-dotted" href="#components">Explore the system</a>
      </div>
      <p class="mono" style="margin-top: var(--space-3);">v{{version}} · {{lastUpdated}} · Caldera clone</p>
    </div>
    <img class="panel" src="../public/brand/halftone-hero.svg" alt="Halftone gradient hero panel — Digital Orange to Cyber Violet">
  </header>

  <!-- STAT GRID — interconnected cards (signatures.connectedCards) -->
  <section>
    <div class="stat-connected">
      <div class="card">
        <span class="badge-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M8 7l-5 5 5 5M16 7l5 5-5 5"/></svg></span>
        <div><div class="stat">70+</div><div class="stat-label">Open-source projects</div></div>
        <svg class="conn conn-r" viewBox="0 0 16 141" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M0 0.5V35.5C0 39.9183 3.58172 43.5 8 43.5C12.4183 43.5 16 39.9183 16 35.5V0.5V140.5V103C16 98.5817 12.4183 95 8 95C3.58172 95 0 98.5817 0 103V140.5V0.5Z"/></svg>
        <svg class="conn conn-b" viewBox="0 0 141 16" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M0.5 0H35.5C39.9183 0 43.5 3.58172 43.5 8C43.5 12.4183 39.9183 16 35.5 16H0.5H140.5H103C98.5817 16 95 12.4183 95 8C95 3.58172 98.5817 0 103 0H140.5H0.5Z"/></svg>
      </div>
      <div class="card">
        <span class="badge-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="M3.5 7l8.5 6 8.5-6"/></svg></span>
        <div><div class="stat">1,103</div><div class="stat-label">Newsletter subscribers</div></div>
        <svg class="conn conn-r" viewBox="0 0 16 141" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M0 0.5V35.5C0 39.9183 3.58172 43.5 8 43.5C12.4183 43.5 16 39.9183 16 35.5V0.5V140.5V103C16 98.5817 12.4183 95 8 95C3.58172 95 0 98.5817 0 103V140.5V0.5Z"/></svg>
        <svg class="conn conn-b" viewBox="0 0 141 16" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M0.5 0H35.5C39.9183 0 43.5 3.58172 43.5 8C43.5 12.4183 39.9183 16 35.5 16H0.5H140.5H103C98.5817 16 95 12.4183 95 8C95 3.58172 98.5817 0 103 0H140.5H0.5Z"/></svg>
      </div>
      <div class="card">
        <span class="badge-icon" aria-hidden="true">in</span>
        <div><div class="stat">5,856</div><div class="stat-label">LinkedIn followers</div></div>
        <svg class="conn conn-r" viewBox="0 0 16 141" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M0 0.5V35.5C0 39.9183 3.58172 43.5 8 43.5C12.4183 43.5 16 39.9183 16 35.5V0.5V140.5V103C16 98.5817 12.4183 95 8 95C3.58172 95 0 98.5817 0 103V140.5V0.5Z"/></svg>
        <svg class="conn conn-b" viewBox="0 0 141 16" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M0.5 0H35.5C39.9183 0 43.5 3.58172 43.5 8C43.5 12.4183 39.9183 16 35.5 16H0.5H140.5H103C98.5817 16 95 12.4183 95 8C95 3.58172 98.5817 0 103 0H140.5H0.5Z"/></svg>
      </div>
      <div class="card">
        <span class="badge-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l2.9 6.26L21.8 9l-5.2 4.64L18.1 21 12 17.27 5.9 21l1.5-7.36L2.2 9l6.9-.74z"/></svg></span>
        <div><div class="stat">218</div><div class="stat-label">GitHub followers</div></div>
        <svg class="conn conn-r" viewBox="0 0 16 141" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M0 0.5V35.5C0 39.9183 3.58172 43.5 8 43.5C12.4183 43.5 16 39.9183 16 35.5V0.5V140.5V103C16 98.5817 12.4183 95 8 95C3.58172 95 0 98.5817 0 103V140.5V0.5Z"/></svg>
        <svg class="conn conn-b" viewBox="0 0 141 16" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M0.5 0H35.5C39.9183 0 43.5 3.58172 43.5 8C43.5 12.4183 39.9183 16 35.5 16H0.5H140.5H103C98.5817 16 95 12.4183 95 8C95 3.58172 98.5817 0 103 0H140.5H0.5Z"/></svg>
      </div>
    </div>
  </section>

  <!-- IDENTITY -->
  <section>
    <h2 class="section">Identity</h2>
    <p class="lead"><strong>Philosophy:</strong> <em>{{identity.philosophy}}</em></p>
    <p class="lead"><strong>Voice in one breath:</strong> {{identity.voiceSummary}}</p>
  </section>

  <!-- COLOR — RAW -->
  <section id="color">
    <h2 class="section">Color · raw palette</h2>
    <p class="lead">Eight Caldera swatches. Templates never reference these directly — they reference semantic tokens, which point here. One loud orange accent; violet and glare are decorative-only.</p>
    <div class="chips">
      {{#each colorRawList}}
      <div class="chip">
        <div class="swatch" style="background: {{hex}};"></div>
        <div class="label">
          <span class="name">{{name}}</span>
          <span class="hex">{{hex}}</span>
        </div>
        <div class="use">{{role}}</div>
      </div>
      {{/each}}
    </div>
  </section>

  <!-- COLOR — SEMANTIC -->
  <section>
    <h2 class="section">Color · semantic tokens</h2>
    <p class="lead">The API surface. Templates consume <code class="mono">--color-*</code> tokens; this layer points back into the raw palette.</p>
    <div class="chips">
      {{#each colorSemanticList}}
      <div class="chip semantic">
        <div class="swatch" style="background: {{hex}};" data-ref="→ {{ref}}"></div>
        <div class="label">
          <span class="name">--color-{{name}}</span>
          <span class="hex">{{hex}}</span>
        </div>
        <div class="use">{{use}}</div>
      </div>
      {{/each}}
    </div>
  </section>

  <!-- TYPOGRAPHY -->
  <section id="type">
    <h2 class="section">Typography</h2>
    <p class="lead">Display is a heavy compact grotesque (Anton — the OFL stand-in for PP Neue Corp Compact Ultrabold) for the name, headings, and stat numbers, set in MIXED case. DM Sans 500 is the body workhorse. Mono is reserved for data signatures.</p>

    <div class="specimen">
      <div class="label">--text-display-xl · Anton · 189px / 0.02em · mixed case</div>
      <div class="preview-display" style="font-size: var(--text-display-xl-size); line-height: var(--text-display-xl-line-height);">More Is More.</div>
    </div>

    <div class="specimen">
      <div class="label">--text-display · Anton · 96px / 0.02em</div>
      <div class="preview-display">Subtraction for life,<br>addition for thought.</div>
    </div>

    <div class="specimen">
      <div class="label">--text-display-lg · Anton · 64px mixed case</div>
      <div class="preview-h1">Building at the intersection of AI, cultural tech &amp; women's health</div>
    </div>

    <div class="specimen">
      <div class="label">--text-body · DM Sans 500 · 16px / 9pt</div>
      <div class="preview-body">I architect AI agents, ship full-stack platforms end-to-end, and teach others to do the same. Featured in multiple media interviews for the minimalist lifestyle philosophy — <em>subtraction for life, addition for thought</em>.</div>
    </div>

    <div class="specimen">
      <div class="label">--text-eyebrow · DM Sans 700 uppercase · 0.08em tracking</div>
      <div class="eyebrow">Editorial eyebrow — the only uppercased label</div>
    </div>

    <div class="specimen">
      <div class="label">--text-mono · JetBrains Mono 400 · 13px / 8pt</div>
      <div class="preview-mono">last updated · {{lastUpdated}} · build N · data/brand.yaml v{{version}}</div>
    </div>
  </section>

  <!-- COMPONENTS -->
  <section id="components">
    <h2 class="section">Components</h2>
    <p class="lead">Flat, friendly geometry: pill buttons at 800px, cards at 40px, tags at 20px, no shadows. Orange fills carry the primary action; everything else is ash on basalt.</p>

    <!-- BUTTONS — the full pill system -->
    <h3 class="comp-title">Buttons</h3>
    <p class="meta" style="margin:0 0 var(--space-1);">Variants — hierarchy by fill: orange primary, ink-hairline secondary, dotted tertiary, ash quiet, and a circular icon button.</p>
    <div class="btn-row">
      <a class="btn btn-primary" href="#">Primary action</a>
      <a class="btn btn-ghost" href="#">Secondary</a>
      <a class="btn btn-dotted" href="#">Tertiary</a>
      <a class="btn btn-quiet" href="#">Quiet</a>
      <button class="btn btn-icon btn-icon--accent" type="button" aria-label="Submit"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg></button>
      <button class="btn btn-icon" type="button" aria-label="More options"><svg viewBox="0 0 24 24" fill="currentColor"><circle cx="5" cy="12" r="2"/><circle cx="12" cy="12" r="2"/><circle cx="19" cy="12" r="2"/></svg></button>
    </div>

    <p class="meta" style="margin:var(--space-2) 0 var(--space-1);">Sizes — small · medium (default) · large.</p>
    <div class="btn-row">
      <a class="btn btn-primary btn-sm" href="#">Small</a>
      <a class="btn btn-primary" href="#">Medium</a>
      <a class="btn btn-primary btn-lg" href="#">Large</a>
    </div>

    <p class="meta" style="margin:var(--space-2) 0 var(--space-1);">With icons — leading or trailing, inheriting the label colour.</p>
    <div class="btn-row">
      <a class="btn btn-primary" href="#"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M8 7l-5 5 5 5M16 7l5 5-5 5"/></svg>View the repo</a>
      <a class="btn btn-ghost" href="#">Read the spec<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg></a>
    </div>

    <p class="meta" style="margin:var(--space-2) 0 var(--space-1);">States — default · hover · active · focus · disabled (a colour shift + a 1px press; flat, never a shadow).</p>
    <div class="btn-row">
      <a class="btn btn-primary" href="#">Default</a>
      <a class="btn btn-primary is-hover" href="#">Hover</a>
      <a class="btn btn-primary is-active" href="#">Active</a>
      <a class="btn btn-primary is-focus" href="#">Focus</a>
      <button class="btn btn-primary" type="button" disabled>Disabled</button>
    </div>

    <div class="field">
      <input type="text" placeholder="Pill input — fully rounded, 1px ink border">
    </div>

    <!-- Dotted accordion rows (collapsed) — Caldera's dotted-edge motif -->
    <div style="display:grid; gap:var(--space-2); max-width:520px; margin:var(--space-3) 0;">
      <div class="card" style="padding:var(--space-3) var(--space-4);">
        <span style="font-family:var(--font-display); font-size:30px; letter-spacing:0.02em;">Expanded</span>
        <p class="meta" style="margin:var(--space-1) 0 0;">Solid ash card — the open accordion panel.</p>
      </div>
      <div class="btn-dotted" style="display:block; border-radius:var(--radius-card); padding:var(--space-3) var(--space-4);">
        <span style="font-family:var(--font-display); font-size:30px; letter-spacing:0.02em;">Collapsed</span>
      </div>
      <div class="btn-dotted" style="display:block; border-radius:var(--radius-card); padding:var(--space-3) var(--space-4);">
        <span style="font-family:var(--font-display); font-size:30px; letter-spacing:0.02em;">Collapsed</span>
      </div>
    </div>

    <!-- Blog cards: halftone thumb + Hazard-Yellow category tag + Anton title -->
    <div class="blog-grid">
      <div class="blog-card">
        <img class="thumb" src="../public/brand/halftone-thumb.svg" alt="">
        <span class="tag">Announcement</span>
        <h3>Shipping agentic workflows in production</h3>
        <span class="date">{{lastUpdated}}</span>
      </div>
      <div class="blog-card">
        <img class="thumb" src="../public/brand/halftone-thumb.svg" alt="">
        <span class="tag">Open Source</span>
        <h3>Free tools I built for the community</h3>
        <span class="date">{{lastUpdated}}</span>
      </div>
      <div class="blog-card">
        <img class="thumb" src="../public/brand/halftone-thumb.svg" alt="">
        <span class="tag">FemTech</span>
        <h3>Cultural technology and women's health</h3>
        <span class="date">{{lastUpdated}}</span>
      </div>
    </div>

    <!-- Logo strip: monochrome marks on white, dotted dividers; reflows 6 → 3×2 → 2×3 -->
    <div class="logo-strip">
      <div class="cell"><img src="../public/brands/gradient-svg-generator-logo.svg" alt="gradient-svg-generator"></div>
      <div class="cell"><img src="../public/brands/github-visitor-counter-logo.svg" alt="github-visitor-counter"></div>
      <div class="cell"><img src="../public/brands/github-readme-suno-cards-logo.svg" alt="github-readme-suno-cards"></div>
      <div class="cell"><img src="../public/brands/echook-logo.svg" alt="echook"></div>
      <div class="cell"><img src="../public/brands/sunostats-logo.svg" alt="SunoStats"></div>
      <div class="cell"><img src="../public/brands/typst-claude-skill-logo.svg" alt="typst-claude-skill"></div>
    </div>

    <!-- Accordion — active item = solid cream card; inactive = dotted ghost rows -->
    <div class="accordion">
      <div class="item-active">
        <h3>AI &amp; RAG systems</h3>
        <p>The expanded item is a solid cream card with its description shown; siblings collapse to dotted-outline ghost rows.</p>
      </div>
      <div class="item-ghost">Accessibility &amp; inclusive design</div>
      <div class="item-ghost">Developer tooling</div>
    </div>

    <!-- Carousel controls — circular dotted-edge arrows -->
    <div style="display:flex; align-items:center; gap:var(--space-3); margin:var(--space-3) 0;">
      <span class="meta">Carousel controls</span>
      <div class="carousel-ctrls">
        <button aria-label="Previous"><img src="../public/brand/arrow-prev.svg" alt=""></button>
        <span class="sep"></span>
        <button aria-label="Next"><img src="../public/brand/arrow-next.svg" alt=""></button>
      </div>
    </div>

    <!-- Newsletter signup — violet panel, pill input + circular arrow -->
    <div class="signup">
      <h3 style="font-family:var(--font-display); font-size:var(--text-display-lg-size); line-height:0.95; letter-spacing:0.02em; margin:0 0 var(--space-3);">Sign up to follow the build.</h3>
      <div class="field-pill">
        <input type="email" placeholder="Type your email here">
        <button class="go" aria-label="Submit">▸</button>
      </div>
    </div>
  </section>

  <!-- SPACING -->
  <section>
    <h2 class="section">Spacing · 8px base</h2>
    <p class="lead">Named scale with a 10px element gap and an 80px section rhythm (<code class="mono">--rhythm-section-large</code>).</p>
    <div class="ruler">
      {{#each spacingList}}
      <div class="ruler-row">
        <span class="name">--space-{{name}}</span>
        <span class="px">{{value}}px</span>
        <span class="bar" style="width: {{value}}px;"></span>
      </div>
      {{/each}}
    </div>
  </section>

  <!-- SIGNATURES -->
  <section>
    <h2 class="section">Decorative signatures</h2>
    <p class="lead">All built on assets Chan owns: the risograph halftone panels (public/brand/), gradient-svg-generator banners + pills, the monogram, and the datestamp. External services (shields.io, trophies, wakatime, streaks) are forbidden.</p>
    <div class="sig-gallery">

      <div class="sig-card">
        <h3>1. Halftone panel — halftone</h3>
        <div class="preview">
          <img src="../public/brand/halftone-hero.svg" alt="Halftone hero panel" loading="lazy" style="max-height: 220px;">
        </div>
        <p class="meta"><strong>Colors:</strong> Digital Orange → Cyber Violet</p>
        <p class="meta"><strong>Use:</strong> {{signatures.halftone.useWhen}}</p>
        <p class="meta"><strong>Don't:</strong> {{signatures.halftone.doNotUseWhen}}</p>
      </div>

      <div class="sig-card">
        <h3>2. Hero band — heroBand</h3>
        <p class="meta"><span>Template: <code class="mono">{{signatures.heroBand.template}}</code></span><span>Height: {{signatures.heroBand.height}}px</span><span>Duration: {{signatures.heroBand.duration}}</span></p>
        <div class="preview">
          <img src="https://gradient-svg-generator.vercel.app/api/svg?text=Chan%20Meng&template={{signatures.heroBand.template}}&height={{signatures.heroBand.height}}&duration={{signatures.heroBand.duration}}" alt="Hero band preview" loading="lazy">
        </div>
        <p class="meta"><strong>Use:</strong> {{signatures.heroBand.useWhen}}</p>
      </div>

      <div class="sig-card">
        <h3>3. Accent eyebrow — goldEyebrow</h3>
        <div class="preview" style="text-align: left;">
          <p class="eyebrow">Featured Work</p>
          <h3 style="font-family: var(--font-display); font-size: var(--text-display-lg-size); letter-spacing: 0.02em; color: var(--color-ink-strong); margin: 0;">Sample display heading</h3>
        </div>
        <p class="meta"><strong>Rule:</strong> {{signatures.goldEyebrow.rule}}</p>
        <p class="meta"><strong>Use:</strong> {{signatures.goldEyebrow.useWhen}}</p>
      </div>

      <div class="sig-card">
        <h3>4. Mono datestamp — monoDatestamp</h3>
        <div class="preview" style="text-align: left;">
          <span class="mono">last updated · {{lastUpdated}} · build 47</span>
        </div>
        <p class="meta"><strong>Use:</strong> {{signatures.monoDatestamp.useWhen}}</p>
      </div>

      <div class="sig-card">
        <h3>5. Monogram divider — monogramDivider</h3>
        <div class="preview">
          <div style="display: flex; align-items: center; gap: 12px; justify-content: center;">
            <span style="flex: 1; height: 2px; background: var(--color-ink-primary); opacity: 0.4;"></span>
            <img src="../public/brands/chan-monkey-logo-black.svg" alt="" style="width: 24px; height: 24px;">
            <span style="flex: 1; height: 2px; background: var(--color-ink-primary); opacity: 0.4;"></span>
          </div>
        </div>
        <p class="meta"><strong>Use:</strong> {{signatures.monogramDivider.useWhen}}</p>
      </div>

      <div class="sig-card">
        <h3>6. Pill rotation — pillRotation</h3>
        <div class="preview">
          <p class="meta">Recoloured to the Caldera palette ({{pillRotationCount}} configured)</p>
          <div style="display: flex; gap: 8px; flex-wrap: wrap; justify-content: center; margin-top: 12px;">
            <img src="https://gradient-svg-generator.vercel.app/api/svg?text=Primary&template=brand-pill-mixed&height=40&duration=8s" alt="" height="40">
            <img src="https://gradient-svg-generator.vercel.app/api/svg?text=Violet&template=brand-pill-violet&height=40&duration=8s" alt="" height="40">
            <img src="https://gradient-svg-generator.vercel.app/api/svg?text=Source&template=brand-pill-ink&height=40&duration=8s" alt="" height="40">
            <img src="https://gradient-svg-generator.vercel.app/api/svg?text=Orange&template=brand-pill-orange&height=40&duration=8s" alt="" height="40">
          </div>
        </div>
        <p class="meta"><strong>Use:</strong> {{signatures.pillRotation.useWhen}}</p>
      </div>

    </div>
  </section>

  <!-- VOICE -->
  <section id="voice">
    <h2 class="section">Voice principles</h2>
    <div class="voice-list">
      {{#each voice.principles}}
      <div class="voice-rule">
        <div class="name">{{name}}</div>
        <div>{{rule}}</div>
        {{#if why}}<div class="why">— {{why}}</div>{{/if}}
      </div>
      {{/each}}
    </div>
  </section>

  <!-- DO / DON'T -->
  <section>
    <h2 class="section">Voice in practice · Do vs Don't</h2>
    <div class="dodont">
      <div class="pair do">
        <div class="label">Do</div>
        <ul style="margin: 0; padding-left: 1.2em;">
          {{#each voice.examples.do}}<li>{{this}}</li>{{/each}}
        </ul>
      </div>
      <div class="pair dont">
        <div class="label">Don't</div>
        <ul style="margin: 0; padding-left: 1.2em;">
          {{#each voice.examples.dont}}<li>{{this}}</li>{{/each}}
        </ul>
      </div>
    </div>
  </section>

  <footer>
    <p class="mono">Generated {{lastUpdated}} from data/brand.yaml v{{version}}</p>
    <p class="meta"><a href="https://github.com/ChanMeng666/ChanMeng666">Source on GitHub</a> · <a href="../dist/brand/DESIGN.md">DESIGN.md</a> · <a href="../dist/brand/design-tokens.json">design-tokens.json</a> · <a href="../dist/brand/theme.css">theme.css</a></p>
  </footer>

</div>
</body>
</html>
