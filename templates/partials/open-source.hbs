## Open source

#### AI agents & tooling

<table>
  <colgroup>
    <col style="width:72px">
    <col style="width:200px">
    <col>
  </colgroup>
{{#each _aiAgentProjects}}  <tr>
    <td>{{#if logo}}<a href="{{default url repoUrl}}" title="{{name}}"><img src="{{logo}}" height="48" alt="{{name}}"></a>{{else}}&nbsp;{{/if}}</td>
    <td><strong><a href="{{default url repoUrl}}">{{briefTagline name}}</a></strong>{{#if _contextLogo.length}}<br><sub>{{#each _contextLogo}}<a href="{{url}}"><img src="{{src}}" height="20" alt="{{alt}}"></a>{{#unless @last}} {{/unless}}{{/each}}</sub>{{/if}}</td>
    <td>{{briefTagline tagline}}{{#if _featuredStackResolved.length}}<br>{{#each _featuredStackResolved}}<img src="{{src}}" height="18" alt="{{name}}" title="{{name}}"> {{/each}}{{/if}}{{#if url}}{{#unless (eq url repoUrl)}} <a href="{{url}}">Live →</a>{{/unless}}{{/if}}{{#if repoUrl}} ![Stars](https://img.shields.io/github/stars/{{repoPath repoUrl}}?style=flat-square&labelColor=1a1a1a){{/if}}</td>
  </tr>
{{/each}}</table>

